---
/**
 * index.astro — Página principal de Taquitos Casa Blanca
 *
 * ┌─────────────────────────────────────────────────────────────────┐
 * │  CÓMO CONFIGURAR LAS IMÁGENES DEL HERO                         │
 * │                                                                 │
 * │  1. Copia tus imágenes a /public/assets/                        │
 * │  2. Edita las props del componente <Hero /> abajo:              │
 * │                                                                 │
 * │     bgImage      → foto de fondo del hero                      │
 * │     logoCircular → logo circular en la nav (arriba-izq)         │
 * │     logoCerdito  → mascota cerdito vaquero sobre el título      │
 * │                                                                 │
 * │  Ejemplo con tus archivos actuales:                             │
 * │     bgImage="/assets/foto_1.jpg"                                │
 * │     logoCircular="/assets/Logo_con_fondo_negro-removebg..."     │
 * │     logoCerdito="/assets/cerdito-removebg-preview.png"          │
 * └─────────────────────────────────────────────────────────────────┘
 */

import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero";
import MenuSection from "../components/MenuSection";
import HistorySection from "../components/HistorySection";
---

<Layout title="Taquitos Casa Blanca | El Sabor de Chiapas en Monterrey">
  <!-- FASE 1: Hero Impactante -->
  <Hero
    client:load
    bgImage="/assets/foto_7.jpg"
    logoCircular="/assets/cerdito-removebg-preview.png"
    logoCerdito="/assets/cerdito_con_sombrero.png"
  />

  <!-- FASE 2: Nuestra Historia -->
  <HistorySection client:visible />

  <!-- FASE 3: Menú interactivo -->
  <MenuSection client:visible />

  <!--
    =============================================
    FASE 3 (próximamente):
      <Galeria client:visible />
      <Contacto client:visible />
    =============================================
  -->
</Layout>
